  "security": {
    "defaultFirewallPolicy": "deny",
    "firewallRules": [
      {
        "id": "rule-control-ot-modbus",
        "sourceZone": "control",
        "destinationZone": "ot",
        "protocol": "tcp",
        "destinationPort": 502,
        "action": "allow",
        "comment": "Allow engineering workstation to read Modbus registers from PLC and RTU"
      },
      {
        "id": "rule-control-ot-dnp3",
        "sourceZone": "control",
        "destinationZone": "ot",
        "protocol": "tcp",
        "destinationPort": 20000,
        "action": "allow",
        "comment": "Allow engineering workstation to poll DNP3 IED"
      },
      {
        "id": "rule-control-ot-bacnet-udp",
        "sourceZone": "control",
        "destinationZone": "ot",
        "protocol": "udp",
        "destinationPort": 47808,
        "action": "allow",
        "comment": "Allow engineering workstation to send BACnet/IP requests to sensors"
      },
      {
        "id": "rule-ot-control-bacnet-reply",
        "sourceZone": "ot",
        "destinationZone": "control",
        "protocol": "udp",
        "destinationPort": 47808,
        "action": "allow",
        "comment": "Allow BACnet/IP unicast replies from sensors back to the workstation"
      },
      {
        "id": "rule-ot-control-any",
        "sourceZone": "ot",
        "destinationZone": "control",
        "protocol": "any",
        "destinationPort": "any",
        "action": "allow",
        "comment": "Allow OT devices to send data to control center (Modbus responses, DNP3 responses)"
      }
    ],
