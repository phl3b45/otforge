{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@schema/*": ["../schema/src/*"]
    }
  }
}
