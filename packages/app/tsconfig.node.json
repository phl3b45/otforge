{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "ignoreDeprecations": "6.0",
    "types": ["electron-vite/node"],
    "paths": {
      "@schema/*": ["../schema/src/*"]
    }
  }
}
