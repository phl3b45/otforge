node_modules
# package-lock.json is intentionally NOT tracked. npm rewrites it with
# platform-specific content on every install, so tracking it caused students'
# `git pull` to fail with lockfile merge conflicts before they could even run
# the app. CI installs with `npm install` (see .github/workflows/build.yml) and
# `.npmrc` sets package-lock=false so npm never regenerates it.
package-lock.json
dist
out
build
!packages/app/build
release
*.log
*.tsbuildinfo
.DS_Store
Thumbs.db
.env
.env.local
packages/app/src/renderer/dist
# OpenPLC Runtime source — downloaded by the CI workflow before Docker build;
# never committed (large C/C++ build tree). To build locally, run:
#   mkdir -p containers/openplc/openplc-src
#   curl -fsSL https://github.com/thiagoralves/OpenPLC_v3/archive/refs/heads/master.tar.gz \
#     | tar -xz --strip-components=1 -C containers/openplc/openplc-src
containers/openplc/openplc-src/
# Test coverage reports — generated artifacts, not committed.
packages/orchestrator/coverage/
