# ICS Simulator — custom Suricata rules
# Complements the Emerging Threats SCADA ruleset (pulled at runtime by suricata-update).
# These rules alert on patterns commonly seen in ICS-targeted attacks.
#
# NOTE: Do NOT use hardcoded IP addresses here. Subnets are dynamically assigned
# at simulation start by findFreeSubnets() and may be anything in 10.x.x.x space.
# Use Suricata variables ($HOME_NET, $EXTERNAL_NET) or port/protocol-based detection
# so rules fire correctly regardless of which /24 Docker picks.

# ── Modbus TCP anomalies ──────────────────────────────────────────────────────

alert tcp $HOME_NET any -> $HOME_NET 502 (msg:"ICS-SIM Modbus TCP Write Multiple Registers"; \
    flow:to_server,established; content:"|00 10|"; offset:7; depth:2; \
    sid:9000001; rev:2; classtype:protocol-command-decode;)

alert tcp $HOME_NET any -> $HOME_NET 502 (msg:"ICS-SIM Modbus TCP Write Single Coil to illegal address"; \
    flow:to_server,established; content:"|05|"; offset:7; depth:1; \
    byte_test:2,>,256,8; \
    sid:9000002; rev:2; classtype:protocol-command-decode;)

alert tcp $HOME_NET any -> $HOME_NET 502 (msg:"ICS-SIM Modbus Force Listen Only Mode"; \
    flow:to_server,established; content:"|08 00 04|"; offset:7; depth:3; \
    sid:9000003; rev:2; classtype:protocol-command-decode;)

# ── DNP3 anomalies ────────────────────────────────────────────────────────────

alert tcp $HOME_NET any -> $HOME_NET 20000 (msg:"ICS-SIM DNP3 Direct Operate received"; \
    flow:to_server,established; content:"|05 64|"; offset:0; depth:2; \
    byte_test:1,&,0x04,3; \
    sid:9000010; rev:2; classtype:protocol-command-decode;)

# ── Port scanning ─────────────────────────────────────────────────────────────

alert tcp any any -> $HOME_NET 502 (msg:"ICS-SIM Modbus port scan detected"; \
    flags:S; threshold:type threshold, track by_src, count 10, seconds 5; \
    sid:9000020; rev:2; classtype:network-scan;)

alert tcp any any -> $HOME_NET 20000 (msg:"ICS-SIM DNP3 port scan detected"; \
    flags:S; threshold:type threshold, track by_src, count 10, seconds 5; \
    sid:9000021; rev:2; classtype:network-scan;)

# ── Cross-zone / lateral movement — detected by protocol, not subnet ──────────
# Subnet-based zone detection is not possible here because subnets are assigned
# dynamically at runtime. We instead detect ICS protocol traffic from hosts that
# are not typical OT controllers — a Modbus write from an unexpected source is
# a strong indicator of lateral movement or an insider attack.

alert tcp any any -> $HOME_NET 502 (msg:"ICS-SIM Unexpected Modbus write to OT device"; \
    flow:to_server,established; content:"|00 10|"; offset:7; depth:2; \
    threshold:type both, track by_src, count 5, seconds 10; \
    sid:9000030; rev:2; classtype:policy-violation;)

# ── Attack machine / red team activity ───────────────────────────────────────
# Detect aggressive scanning toward any simulation host on ICS ports.

alert tcp any any -> $HOME_NET 502 (msg:"ICS-SIM Aggressive Modbus connection attempt"; \
    flags:S; threshold:type threshold, track by_src, count 20, seconds 10; \
    sid:9000040; rev:2; classtype:attempted-recon;)

alert icmp any any -> $HOME_NET any (msg:"ICS-SIM ICMP sweep toward simulation hosts"; \
    itype:8; threshold:type threshold, track by_src, count 5, seconds 2; \
    sid:9000041; rev:2; classtype:network-scan;)

alert tcp any any -> $HOME_NET 80 (msg:"ICS-SIM HTTP scan toward simulation web server"; \
    flags:S; threshold:type threshold, track by_src, count 10, seconds 5; \
    sid:9000042; rev:1; classtype:network-scan;)

# ── nmap / service fingerprinting ────────────────────────────────────────────

alert tcp any any -> $HOME_NET any (msg:"ICS-SIM nmap SYN scan detected"; \
    flags:S,12; threshold:type threshold, track by_src, count 15, seconds 3; \
    sid:9000050; rev:1; classtype:network-scan;)
