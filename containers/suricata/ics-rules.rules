# ICS Simulator — custom Suricata rules
# Complements the Emerging Threats SCADA ruleset (pulled at runtime by suricata-update).
# These rules alert on patterns commonly seen in ICS-targeted attacks.

# ── Modbus TCP anomalies ──────────────────────────────────────────────────────

alert tcp any any -> any 502 (msg:"ICS-SIM Modbus TCP Write Multiple Registers"; \
    flow:to_server,established; content:"|00 10|"; offset:7; depth:2; \
    sid:9000001; rev:1; classtype:protocol-command-decode;)

alert tcp any any -> any 502 (msg:"ICS-SIM Modbus TCP Write Single Coil to illegal address"; \
    flow:to_server,established; content:"|05|"; offset:7; depth:1; \
    byte_test:2,>,256,8; \
    sid:9000002; rev:1; classtype:protocol-command-decode;)

alert tcp any any -> any 502 (msg:"ICS-SIM Modbus Force Listen Only Mode"; \
    flow:to_server,established; content:"|08 00 04|"; offset:7; depth:3; \
    sid:9000003; rev:1; classtype:protocol-command-decode;)

# ── DNP3 anomalies ────────────────────────────────────────────────────────────

alert tcp any any -> any 20000 (msg:"ICS-SIM DNP3 Direct Operate received"; \
    flow:to_server,established; content:"|05 64|"; offset:0; depth:2; \
    byte_test:1,&,0x04,3; \
    sid:9000010; rev:1; classtype:protocol-command-decode;)

# ── Brute force / scanning ────────────────────────────────────────────────────

alert tcp any any -> any 502 (msg:"ICS-SIM Modbus port scan detected"; \
    flags:S; threshold:type threshold, track by_src, count 10, seconds 5; \
    sid:9000020; rev:1; classtype:network-scan;)

alert tcp any any -> any 20000 (msg:"ICS-SIM DNP3 port scan detected"; \
    flags:S; threshold:type threshold, track by_src, count 10, seconds 5; \
    sid:9000021; rev:1; classtype:network-scan;)

# ── Cross-zone traffic (IT→OT) ────────────────────────────────────────────────

alert ip 172.20.20.0/24 any -> 172.20.10.0/24 any (msg:"ICS-SIM IT to OT lateral movement"; \
    threshold:type both, track by_src, count 20, seconds 10; \
    sid:9000030; rev:1; classtype:policy-violation;)

# ── Attack machine activity ───────────────────────────────────────────────────

alert tcp 172.20.40.0/24 any -> 172.20.10.0/24 any (msg:"ICS-SIM Attack machine connecting to OT"; \
    flags:S; \
    sid:9000040; rev:1; classtype:attempted-recon;)

alert icmp 172.20.40.0/24 any -> any any (msg:"ICS-SIM Attack machine ICMP sweep"; \
    itype:8; threshold:type threshold, track by_src, count 5, seconds 2; \
    sid:9000041; rev:1; classtype:network-scan;)
